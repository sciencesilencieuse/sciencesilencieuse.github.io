				<pubDate>Sat, 06 Mar 2021 14:20:50 +0100</pubDate>
				<guid>https://sciencesilencieuse.github.io/maths/stat/acp/</guid>
				<description>&lt;style&gt;&#xA; #correc&#xA;  {&#xA;    color: #006C65;&#xA;    border-left: solid 10px #C7DDDC;&#xA;  }&#xA; #comm&#xA;  {&#xA;    color: #004D80;&#xA;    border-left: solid 10px #B3CAD9;&#xA;  }&#xA; #commsum&#xA;  {&#xA;    color: #004D80;&#xA;  }&#xA; #correcsum&#xA;  {&#xA;    color: #006C65;&#xA;  }&#xA;  #grosseformule &#xA;{&#xA;    overflow-x: auto; &#xA;}&#xA;&lt;/style&gt;&#xA;&lt;style&gt;&#xA;/* ===== iframes Plotly responsives ===== */&#xA;.plot-frame {&#xA;  width: 100%;&#xA;  border: 0;&#xA;  display: block;               /* supprime l&#39;espace fantome sous l&#39;iframe */&#xA;}&#xA;.plot-frame {&#xA;  aspect-ratio: 16 / 10;        /* simple placeholder avant le premier message */&#xA;}&#xA;&lt;/style&gt;&#xA;&lt;script&gt;&#xA;/* Hauteur exacte envoyee par chaque graphe : remplace le ratio CSS. */&#xA;window.addEventListener(&#39;message&#39;, function (e) {&#xA;  if (!e.data || e.data.type !== &#39;plotly-autoresize&#39;) return;&#xA;  document.querySelectorAll(&#39;.plot-frame&#39;).forEach(function (f) {&#xA;    if (f.contentWindow === e.source) {&#xA;      f.style.height = e.data.height + &#39;px&#39;;&#xA;      f.style.aspectRatio = &#39;auto&#39;;&#xA;    }&#xA;  });&#xA;});&#xA;&lt;/script&gt;&#xA;&lt;h1 id=&#34;analyse-en-composantes-principales&#34;&gt;Analyse en composantes principales&lt;/h1&gt;&#xA;&lt;script&gt;&#xA;document.addEventListener(&#34;DOMContentLoaded&#34;, function() {&#xA;function isMobile() {&#xA;return window.innerWidth &lt;= 768;&#xA;}&#xA;&#xA;function replaceIframesWithImages() {&#xA;if (isMobile()) {&#xA;const iframes = document.querySelectorAll(&#39;iframe&#39;);&#xA;iframes.forEach((iframe) =&gt; {&#xA;    const src = iframe.getAttribute(&#39;src&#39;);&#xA;    if (src.endsWith(&#39;.html&#39;)) {&#xA;        const imgSrc = src.replace(&#39;.html&#39;, &#39;.png&#39;);&#xA;        const img = document.createElement(&#39;img&#39;);&#xA;        img.setAttribute(&#39;src&#39;, imgSrc);&#xA;        img.setAttribute(&#39;width&#39;, &#39;100%&#39;);&#xA;        img.setAttribute(&#39;style&#39;, iframe.getAttribute(&#39;style&#39;));&#xA;        iframe.parentNode.replaceChild(img, iframe);&#xA;    }&#xA;});&#xA;}&#xA;}&#xA;&#xA;// Exécute la fonction après le chargement de la page&#xA;replaceIframesWithImages();&#xA;});&#xA;&lt;/script&gt;&#xA;&lt;div style=&#34;position:relative; width:800px; max-width: 100%; margin-left: auto;margin-right: auto;box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);&#34;&gt;&#xA;&lt;div style=&#34;position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;&#34;&gt;&#xA;&#x9;&#x9;&#x9;&lt;iframe allow=&#34;accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen&#34; loading=&#34;eager&#34; referrerpolicy=&#34;strict-origin-when-cross-origin&#34; src=&#34;https://www.youtube.com/embed/sRMplEDuEig?autoplay=0&amp;amp;controls=1&amp;amp;end=0&amp;amp;loop=0&amp;amp;mute=0&amp;amp;start=0&#34; style=&#34;position: absolute; top: 0; left: 0; width: 100%; height: 100%; border:0;&#34; title=&#34;YouTube video&#34;&gt;&lt;/iframe&gt;&#xA;&#x9;&#x9;&lt;/div&gt;&#xA;&#xA;&lt;/div&gt;&#xA;&lt;br&gt;&#xA;&lt;h2 id=&#34;les-axes-qui-tiraillent-territorialement-la-france&#34;&gt;Les axes qui tiraillent territorialement la France&lt;/h2&gt;&#xA;&lt;p&gt;Un autre exemple sur le modèle de celui des prénoms dans la vidéo.&lt;/p&gt;</description>
			</item>
